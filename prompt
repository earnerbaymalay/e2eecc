     fun hashPin(pin: String): Pair<ByteArray, ByteArray> {
         val salt = ByteArray(32).also { SecureRandom().nextBytes(it) }
         val factory = SecretKeyFactory.getInstance("PBKDF2WithHmacSHA256")
         val spec = PBEKeySpec(pin.toCharArray(), salt, 100_000, 256)
         val hash = factory.generateSecret(spec).encoded
         Arrays.fill(spec.password, '\u0000')
         return Pair(hash, salt)
     }

     fun verifyPin(pin: String, storedHash: ByteArray, storedSalt: ByteArray): Boolean {
         val factory = SecretKeyFactory.getInstance("PBKDF2WithHmacSHA256")
         val spec = PBEKeySpec(pin.toCharArray(), storedSalt, 100_000, 256)
         val testHash = factory.generateSecret(spec).encoded
         Arrays.fill(spec.password, '\u0000')
         return MessageDigest.isEqual(testHash, storedHash)
     }

