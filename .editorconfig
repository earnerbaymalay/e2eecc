# Cypherchat EditorConfig
# https://editorconfig.org

root = true

# Global defaults
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# Kotlin files
[*.kt]
indent_size = 4
max_line_length = 120

# Kotlin build files (Gradle Kotlin DSL)
[*.kts]
indent_size = 4
max_line_length = 140

# Markdown docs
[*.md]
indent_size = 2
trim_trailing_whitespace = false
max_line_length = 120

# YAML (CI configs)
[*.yml]
indent_size = 2

# JSON
[*.json]
indent_size = 2

# XML (Android resources)
[*.xml]
indent_size = 4

# Shell scripts
[*.sh]
indent_size = 2

# ProGuard rules
[*.pro]
indent_size = 2

# Gradle properties
[*.properties]
indent_style = space
indent_size = 4
